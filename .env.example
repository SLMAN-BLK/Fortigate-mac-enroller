# ── JWT ──────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key
TOKEN_EXPIRE_MIN=30

# ── Active Directory (tried in order until one responds) ─────
AD_PORT=389
AD_DOMAIN=example.local
AD_BASE_DN=DC=example,DC=local
AD_SERVERS=dc1.example.local,dc2.example.local,dc3.example.local

# Least-privilege reader account
AD_READER_USER=reader@example.local
AD_READER_PASS=your-ad-password

# ── FortiGate — TFC ──────────────────────────────────────────
FG_TFC_IP=x.x.x.x
FG_TFC_USER=api-user
FG_TFC_KEY=your-api-key
FG_TFC_GROUP=wifi-group

# ── FortiGate — DFC ──────────────────────────────────────────
FG_DFC_IP=x.x.x.x
FG_DFC_USER=api-user
FG_DFC_KEY=your-api-key
FG_DFC_GROUP=wifi-group

# ── FortiGate — RMC ──────────────────────────────────────────
FG_RMC_IP=x.x.x.x
FG_RMC_USER=api-user
FG_RMC_KEY=your-api-key
FG_RMC_GROUP=wifi-group

# ── MariaDB ──────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=dbuser
DB_PASS=dbpassword
DB_NAME=database_name
